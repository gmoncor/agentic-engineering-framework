{
  "hooks": {
    "BeforeTool": [
      {
        "_comment": "Bloqueante: impide escribir codigo no declarado en una task de la spec aprobada.",
        "matcher": "write_file|edit_file",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}hooks${/}sdd-pipeline-guard.js\""
          }
        ]
      },
      {
        "_comment": "Advisory: verifica formato de commit y previene scaffolding leaks.",
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}hooks${/}sdd-commit-guard.js\""
          }
        ]
      },
      {
        "_comment": "Bloqueante (opt-in en hooks/config.json): impide git commit/merge sin revision adversarial del codigo.",
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}hooks${/}sdd-review-gate.js\""
          }
        ]
      }
    ]
  }
}
