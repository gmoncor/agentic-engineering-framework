# ===========================================
# Documentos de TU proyecto (no subir al repo)
# ===========================================
# Estas carpetas contienen documentacion especifica
# de tu proyecto, no las plantillas del framework.
# Las plantillas (dev_templates/) SI se versionan.

# ai_docs/core/ incluye documentos de ejemplo en este repo.
# En TU proyecto, descomenta las siguientes lineas para proteger tus documentos:
# ai_docs/core/*
# !ai_docs/core/.gitkeep

ai_docs/tasks/*
!ai_docs/tasks/.gitkeep

ai_docs/refs/*
!ai_docs/refs/.gitkeep

# ===========================================
# Archivos sensibles
# ===========================================
.env
.env.*
!.env.example

# ===========================================
# Dependencias
# ===========================================
node_modules/
vendor/
__pycache__/
*.pyc
.venv/
venv/

# ===========================================
# Claude Code (local configs, no versionar)
# ===========================================
.claude/settings.local.json
.claude/projects/
.claude/todos/
.claude/credits.json

# ===========================================
# IDEs y herramientas
# ===========================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ===========================================
# Build y cache
# ===========================================
dist/
build/
.next/
.nuxt/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
